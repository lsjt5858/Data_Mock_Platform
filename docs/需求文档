### 8.3 关键代码片段

**后端生成逻辑伪代码：**
```python
def generate_data(config, count):
    validator.validate(config)  # 验证
    data = []
    
    for i in range(count):
        row = {}
        for field in config.fields:
            value = FieldGenerator.generate(field)
            if config.include_null and random() < 0.3:
                value = None
            row[field.name] = value
        data.append(row)
    
    return data
```

**前端生成逻辑伪代码：**
```jsx
const handleGenerate = async () => {
    const config = {
        fields: fieldList,
        count: rowCount,
        include_null: includeNull
    };
    
    setLoading(true);
    try {
        const response = await apiService.generate(config);
        setData(response.data.rows);
        setTotal(response.data.total);
    } catch (error) {
        message.error(error.message);
    } finally {
        setLoading(false);
    }
};
```

